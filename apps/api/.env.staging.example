NODE_ENV=staging
PORT=5000
FRONTEND_URL=https://staging.example.com
CORS_ORIGIN=https://staging.example.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
RATE_LIMIT_SKIP_PATHS=/api/checkout/webhooks/stripe

DATABASE_URL=replace_with_postgresql_connection_string_with_sslmode_require

JWT_ACCESS_SECRET=replace_with_32_plus_character_staging_access_secret
JWT_REFRESH_SECRET=replace_with_32_plus_character_staging_refresh_secret
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_LOCKOUT_MS=900000

REDIS_URL=replace_with_rediss_connection_string
REDIS_TLS=true
QUEUE_PREFIX=marketo-staging
QUEUE_WORKER_CONCURRENCY=5
CART_SUMMARY_CACHE_TTL_SECONDS=60
CART_COUNT_CACHE_TTL_SECONDS=60

CLOUDINARY_CLOUD_NAME=your_staging_cloud_name
CLOUDINARY_API_KEY=your_staging_api_key
CLOUDINARY_API_SECRET=your_staging_api_secret
CLOUDINARY_UPLOAD_FOLDER=multi-vendor-ecommerce/staging

STRIPE_SECRET_KEY=replace_with_stripe_test_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_signing_secret

GMAIL_USER=staging-sender@example.com
GMAIL_APP_PASSWORD=your_16_character_app_password
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=465
GMAIL_SMTP_SECURE=true
GMAIL_FROM_NAME=Marketo Staging

ADMIN_NAME=Platform Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_staging_admin_password

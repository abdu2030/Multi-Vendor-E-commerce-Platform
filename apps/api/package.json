{
  "name": "@multivendor/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node node_modules/@nestjs/cli/bin/nest.js start --watch",
    "prebuild": "npm run prisma:generate",
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.build.json --incremental false",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "prisma:generate": "node ../../node_modules/prisma/build/index.js generate",
    "prisma:status": "node ../../node_modules/prisma/build/index.js migrate status",
    "prisma:migrate": "node ../../node_modules/prisma/build/index.js migrate dev",
    "prisma:deploy": "node ../../node_modules/prisma/build/index.js migrate deploy",
    "prisma:status:production": "node scripts/deploy-production-db.js --env-path .env.production --status",
    "prisma:deploy:production": "node scripts/deploy-production-db.js --env-path .env.production",
    "prisma:studio": "node ../../node_modules/prisma/build/index.js studio",
    "seed": "node prisma/seed.js",
    "seed:admin": "node prisma/seed.js",
    "seed:starter": "node prisma/seed.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "11.1.27",
    "@nestjs/platform-express": "11.1.27",
    "@prisma/adapter-pg": "6.19.3",
    "@prisma/client": "6.19.3",
    "body-parser": "^2.3.0",
    "bullmq": "^5.80.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "22.3.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "11.1.27",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.1.0",
    "@types/nodemailer": "^8.0.1",
    "eslint": "^9.32.0",
    "jest": "^30.0.5",
    "prisma": "6.19.3",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3"
  }
}

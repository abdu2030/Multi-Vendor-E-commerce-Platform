# Root deployment reference. App-specific examples remain in apps/api/.env.example and apps/web/.env.example.
# Do not put real credentials in this file.

# API runtime
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://your-frontend.example.com
CORS_ORIGIN=https://your-frontend.example.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
RATE_LIMIT_SKIP_PATHS=/api/checkout/webhooks/stripe

# PostgreSQL. Production must use TLS and a restricted managed database account.
DATABASE_URL=replace_with_postgresql_connection_string_with_sslmode_require

# JWT. Use two different 32+ character server-only secrets.
JWT_ACCESS_SECRET=replace_with_32_plus_character_access_secret
JWT_REFRESH_SECRET=replace_with_32_plus_character_refresh_secret
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_ACCESS_ISSUER=marketo-api
JWT_ACCESS_AUDIENCE=marketo-web
JWT_REFRESH_TOKEN_TTL_DAYS=30

# Account security
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_LOCKOUT_MS=900000

# Redis/BullMQ. Production must use rediss:// with authentication and network restrictions.
REDIS_URL=replace_with_rediss_connection_string
REDIS_TLS=true
QUEUE_PREFIX=marketo-production
QUEUE_WORKER_CONCURRENCY=5
CART_SUMMARY_CACHE_TTL_SECONDS=60
CART_COUNT_CACHE_TTL_SECONDS=60

# Cloudinary server-only credentials
CLOUDINARY_CLOUD_NAME=replace_with_cloud_name
CLOUDINARY_API_KEY=replace_with_api_key
CLOUDINARY_API_SECRET=replace_with_api_secret
CLOUDINARY_UPLOAD_FOLDER=multi-vendor-ecommerce/production

# Stripe server-only credentials. Use live keys for real production payments.
STRIPE_SECRET_KEY=replace_with_stripe_live_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_signing_secret
ALLOW_TEST_STRIPE_KEYS=false

# Gmail SMTP server-only credentials
GMAIL_USER=sender@example.com
GMAIL_APP_PASSWORD=replace_with_gmail_app_password
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=465
GMAIL_SMTP_SECURE=true
GMAIL_FROM_NAME=Marketo

# Admin bootstrap. Rotate after first use if shared with deployment operators.
ADMIN_NAME=Platform Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_production_admin_password

# Web build-time public values. Only NEXT_PUBLIC_* values may be exposed to the browser.
NEXT_PUBLIC_API_URL=https://your-api.example.com/api
NEXT_PUBLIC_APP_NAME=MultiVendor Marketplace